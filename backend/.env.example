# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=miniledger
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_64_chars

# ── Session (OAuth handshake only) ────────────────────────────────────────────
SESSION_SECRET=your_session_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Frontend URL (for CORS + OAuth redirect) ─────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email Notifications ───────────────────────────────────────────────────────
# Option 1: Gmail SMTP (default)
#   MAIL_SERVICE=gmail
#   Create an App Password at: https://myaccount.google.com/apppasswords
MAIL_SERVICE=gmail
MAIL_USER=your_gmail_address@gmail.com
MAIL_PASS=your_gmail_app_password

# Option 2: SendGrid
#   MAIL_SERVICE=sendgrid
#   SENDGRID_API_KEY=your_sendgrid_api_key

# ── Large Transaction Alert Threshold ────────────────────────────────────────
# Transactions above this amount trigger an immediate email alert
LARGE_TXN_THRESHOLD=1000
